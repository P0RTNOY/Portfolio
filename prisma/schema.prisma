generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id                  String   @id @default(cuid()) @db.Text
  title               String   @db.Text
  slug                String   @unique @db.Text
  shortDescription    String   @map("short_description") @db.Text
  fullDescription     String   @default("") @map("full_description") @db.Text
  techStack           String   @default("[]") @map("tech_stack") @db.Text
  githubUrl           String?  @map("github_url") @db.Text
  liveUrl             String?  @map("live_url") @db.Text
  imageUrl            String?  @map("image_url") @db.Text
  screenshots         String   @default("[]") @db.Text
  status              String   @default("planned") @db.Text
  featured            Boolean  @default(false)
  role                String?  @db.Text
  highlights          String   @default("[]") @db.Text
  problemSolved       String?  @map("problem_solved") @db.Text
  technicalChallenges String?  @map("technical_challenges") @db.Text
  displayOrder        Int      @default(0) @map("display_order")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([featured, displayOrder])
  @@index([status])
  @@index([createdAt])
  @@map("projects")
}

model Course {
  id               String   @id @default(cuid()) @db.Text
  title            String   @db.Text
  slug             String   @unique @db.Text
  provider         String   @default("Udemy") @db.Text
  courseUrl        String   @map("course_url") @db.Text
  imageUrl         String?  @map("image_url") @db.Text
  shortDescription String   @map("short_description") @db.Text
  fullDescription  String   @default("") @map("full_description") @db.Text
  skills           String   @default("[]") @db.Text
  instructor       String?  @db.Text
  status           String   @default("planned") @db.Text
  progress         Int      @default(0)
  certificateUrl   String?  @map("certificate_url") @db.Text
  credentialUrl    String?  @map("credential_url") @db.Text
  startedAt        DateTime? @map("started_at") @db.Date
  completedAt      DateTime? @map("completed_at") @db.Date
  featured         Boolean  @default(false)
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([featured, displayOrder])
  @@index([status])
  @@index([createdAt])
  @@map("courses")
}

model SiteSettings {
  id                String   @id @default("default") @db.Text
  siteName          String   @default("Portfolio") @map("site_name") @db.Text
  heroEyebrow       String   @default("Generic portfolio") @map("hero_eyebrow") @db.Text
  heroTitle         String   @default("Your Name, professional title, and selected work.") @map("hero_title") @db.Text
  heroIntro         String   @default("A concise introduction placeholder for the kind of work, outcomes, and collaborations this portfolio will represent.") @map("hero_intro") @db.Text
  primaryCtaLabel   String   @default("View Projects") @map("primary_cta_label") @db.Text
  secondaryCtaLabel String   @default("Contact Me") @map("secondary_cta_label") @db.Text
  aboutTitle        String   @default("A concise professional summary will live here.") @map("about_title") @db.Text
  aboutSummary      String   @default("Use this space for a short editable introduction. Keep it focused on the type of work, values, and outcomes you want the portfolio to communicate.") @map("about_summary") @db.Text
  skillsTitle       String   @default("Editable skill categories.") @map("skills_title") @db.Text
  skillsSummary     String   @default("These categories are generic for now and can be edited from the admin dashboard.") @map("skills_summary") @db.Text
  skills            String   @default("[\"Frontend\",\"Backend\",\"Design Systems\",\"Automation\",\"AI Integrations\",\"Deployment\"]") @db.Text
  contactTitle      String   @default("Generic contact details.") @map("contact_title") @db.Text
  contactSummary    String   @default("Add preferred email, social links, or a contact form once you are ready to personalize the portfolio.") @map("contact_summary") @db.Text
  contactEmail      String   @default("hello@example.com") @map("contact_email") @db.Text
  githubUrl         String?  @map("github_url") @db.Text
  linkedinUrl       String?  @map("linkedin_url") @db.Text
  resumeUrl         String?  @map("resume_url") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
}
